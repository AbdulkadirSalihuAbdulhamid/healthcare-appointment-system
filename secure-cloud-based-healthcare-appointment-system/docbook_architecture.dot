digraph docbook_architecture {
    graph [
        rankdir=LR,
        bgcolor=white,
        fontname="Arial",
        fontsize=20,
        labelloc=t,
        label="DocBook Production Architecture (Render.com)",
        pad=0.5,
        nodesep=1.0,
        ranksep=1.5,
        dpi=300
    ];
    node [
        shape=box,
        style="rounded,filled",
        fillcolor="#FFFFFF",
        color="#1565C0",
        penwidth=2.5,
        fontname="Arial",
        fontsize=17,
        margin="0.4,0.25"
    ];
    edge [
        fontname="Arial",
        fontsize=15,
        color="#000000",
        penwidth=2.5,
        arrowsize=1.1
    ];

    browser [
        label="WEB BROWSER\n(Patient, Doctor, Admin)",
        fillcolor="#FFF9C4",
        color="#F57F17",
        penwidth=2.5
    ];

    subgraph cluster_render {
        label="RENDER CLOUD (PaaS)";
        style="rounded,filled";
        fillcolor="#E3F2FD";
        color="#1565C0";
        penwidth=3;
        fontname="Arial";
        fontsize=16;
        margin=28;

        router [
            label="HTTPS EDGE ROUTER\n(TLS / SSL termination)",
            fillcolor="#64B5F6",
            color="#0D47A1",
            fontcolor="#000000"
        ];

        app [
            label="GUNICORN SERVER\nDjango Application\nWhiteNoise (static files)",
            fillcolor="#81C784",
            color="#1B5E20",
            fontcolor="#000000"
        ];

        router -> app [label="HTTP", minlen=2]
    }

    database [
        label="POSTGRESQL DATABASE\n(Managed, isolated)",
        fillcolor="#BA68C8",
        color="#4A148C",
        fontcolor="#000000"
    ];

    browser -> router [label="HTTPS", minlen=2];
    app -> database [dir=both, label="SQL", minlen=2];
}
